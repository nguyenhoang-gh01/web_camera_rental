{
  "name": "focus-camera-storefront",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js backend for the FOCUS CAMERA storefront clone",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "sync:catalog": "python scripts/sync_real_catalog.py",
    "seed:catalog": "cmd /c \"mysql -u root focus_camera < database\\seeds\\catalog_seed.sql\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.21.2",
    "mysql2": "^3.15.2"
  }
}
